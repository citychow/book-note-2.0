<%- include('partials/header.ejs'); -%>


    <div class="mt d-flex align-items-center justify-content-between">
    <div><form class="d-flex align-items-center" role="search" id="search-form">
        <input class="form-control me-2" type="search" placeholder="Type Book Name to search..." id="search-input" aria-label="Search">
    </form></div>
    <div><form action="/sort" method="post" class="d-flex align-items-center justify-content-end text-nowrap">
    Sort by:
        <select class="form-select" name="sortByField" aria-label="field">
            <option value="inputDate">Date</option>
            <option value="rating">Rating</option>
            <option value="name">Book Name</option>
        </select>
        <select class="form-select" name="sortOrder" aria-label="order">
            <option value="asc">>Ascending</option>
            <option value="desc">Descending</option>
        </select>
        <button type="submit" class="btn btn-secondary" name="sortButton">Apply</button>
    </form></div>
    </div>
    </div>


<div class="container mt-4" id="book-container">
    <div class="row mt-2 d-flex justify-content-center">
        <% if (listItems.length === 0) { %>
            <p>No book reviews yet. Click "Add a book" to create your first review!</p>
        <% } else { %>
        <div class="carousel-container d-flex">
            <button class="nav-btn prev" id="prevBtn">←</button>
            <div class="scroll-wrapper" id="scroll-wrapper">
            <% listItems.forEach(item => { %>
                <div class="mb-3 card">
                    <img src="<%= item.url %>" class="rounded-3 img-fluid text-center img" alt="<%= item.name %>" loading="lazy">
                    <h4 class="text-center"><%= item.name %></h4>
                    <div class = "details">
                    <div class="row d-flex mb-2"> 
                        <div class="col-6">Rating: <%= item.rating %></div>
                        <div class="col-6 text-end"><%= item.inputDate %></div>
                    </div>
                    <div class="row d-flex mb-2">
                        <div class="line-clamp"> <em><%= item.review %></em> </div>
                    </div>
                    </div>
                    <div class="btn-group"> 
                        <form action="/view" method="post" style="display: inline;">
                            <button type="submit" class="btn btn-sm btn-outline-primary" name="viewItemId" value="<%= item.id %>">View</button>
                        </form>
                        <form action="/edit" method="post" style="display: inline;">
                            <button type="submit" class="btn btn-sm btn-outline-secondary" name="editItemId" value="<%= item.id %>">Edit</button>
                        </form> 
                        <form action="/delete" onsubmit="return confirm('The book review of <%= item.name %> will be deleted and cannot be recovered. \nAre you sure?');" method="post" style="display: inline;">
                            <button type="submit" class="btn btn-sm btn-outline-danger" name="deleteItemId" value="<%= item.id %>">Delete</button>
                        </form>
                    </div> 
                </div>
            <% })} %>
            </div>
            <button class="nav-btn next" id="nextBtn">→</button>
        </div>
    </div> 
</div> 
<script src="/js/carousel.js"></script>
<script>
    // Add search functionality (book name only)
    const searchInput = document.getElementById('search-input');
    const bookContainer = document.getElementById('book-container');

    searchInput.addEventListener('input', function() {
        const query = this.value.toLowerCase();
        const cards = bookContainer.querySelectorAll('.card');

        cards.forEach(card => {
            const title = card.querySelector('h4').textContent.toLowerCase();
            if (title.includes(query)) {
                card.style.display = '';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>
<%- include('partials/footer.ejs'); -%>

