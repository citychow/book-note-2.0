<%- include('partials/header.ejs'); -%>
<h2 class="mt-4"> Edit an existing book review </h2>
<form action="/saveEdit" onsubmit="return confirm('All changes will be saved. Are you sure?');" method="post">
    <div class="mb-3">
        <label for="bookname" class="form-label">Book Name</label>
        <input type="text" class="form-control" id="bookname" name="bookname" autofocus="true" value="<%= bookname %>" required>
    </div>
    <div class="mb-3">
        <label for="isbn" class="form-label">ISBN</label>
        <input type="number" class="form-control" id="isbn" value="<%= isbn %>" name="isbn" required>
    </div>
    <div class="mb-3">
        <label for="rating" class="form-label">Rating (1-10)</label>
        <input type="number" step="0.1" class="form-control" id="rating" name="rating" min="1" max="10" value="<%= rating %>" required>
    </div>
    <div class="mb-3">
        <label for="date" class="form-label">Date</label>
        <input type="date" class="form-control" id="date" name="date" value="<%= date %>" required>
    </div>
    <div class="mb-3">
        <label for="review" class="form-label">Review</label>
        <textarea class="form-control" id="review" name="review"><%= review %></textarea>
    </div>
    <button type="submit" class="btn btn-outline-primary" name="editItemId" value="<%= id %>">Save Changes</button>
    
</form>
<form action="/" onsubmit="return confirm('All changes will be discarded. \nAre you sure?');" method="get">
    <button type="submit" class="btn btn-outline-secondary">Discard Changes</button>
</form>
<%- include('partials/footer.ejs'); -%>
